1067: pub fn register_combat_kernel_runtime(app: &mut App) {
1068:     let mut registry = CombatKernelRegistry::new();
1069:     registry.register(crate::combat::twin_core::TwinCoreHook);
1070:     registry.register(crate::combat::battery_loop::BatteryLoopHook);
1071:     registry.register(crate::combat::holy_support::HolySupportHook);
1072:     registry.register(crate::combat::predator_loop::PredatorLoopHook);
1073:     registry.register(crate::combat::precision_mind_game::PrecisionMindGameHook);
1074: 
1075:     app.init_resource::<CombatKernelState>()
1076:         .init_resource::<crate::combat::twin_core::TwinCoreState>()
1077:         .init_resource::<crate::combat::battery_loop::BatteryLoopState>()
1078:         .init_resource::<crate::combat::holy_support::HolySupportState>()
1079:         .init_resource::<crate::combat::predator_loop::PredatorLoopState>()
1080:         .init_resource::<crate::combat::precision_mind_game::PrecisionMindGameState>()
1081:         .add_systems(
1082:             Update,
1083:             (
1084:                 crate::combat::battery_loop::apply_battery_loop_transitions_system,
1085:                 crate::combat::predator_loop::apply_predator_loop_transitions_system,
1086:                 crate::combat::twin_core::apply_twin_core_transitions_system,
1087:                 crate::combat::holy_support::apply_holy_support_transitions_system,
1088:                 crate::combat::precision_mind_game::apply_precision_mind_game_transitions_system,
1089:             ),
1090:         )
1091:         .insert_resource(registry);
1092: }
