// Test/preview VFX — a continuous rising flame, for exercising the
// bevy-enoki-vfx skill and as a sample to tweak in the bevy_enoki web editor /
// `enoki2d_editor`. NOT tied to any Digimon kit; lives in `assets/vfx/` as a
// generic procedural atom (skill: reusable atoms go here).
//
// Visual verb: persistent "fire" aura/ember (L1, procedural-first, no asset).
// The rising look comes from a fixed upward `direction` plus upward
// `linear_acceleration` (heat speeding up as it climbs); the flicker comes from
// per-particle randomness on speed/direction/scale. HDR-overbright color_curve
// (white-hot core -> orange -> deep red) carries the bloom glow on the
// `Camera2d + Hdr + Bloom::NATURAL + Tonemapping::TonyMcMapface` path.
//
// enoki `Particle2dEffect` schema — all 19 fields listed because the RON loader
// has no field defaults (MEM098). Rval = (value, randomness); Vec2 = (x, y),
// +Y is up. Continuous emitter (spawn_rate > 0): no `OneShot`, loops forever.
(
    // Dense continuous feed so the flame body reads as one coherent tongue.
    spawn_rate: 55.0,
    spawn_amount: 2,
    // Seed from a small disc so the base is a few px wide, not a point.
    emission_shape: Circle(10.0),
    // Short life with variance — particles climb a short distance then die.
    lifetime: (0.55, 0.3),
    // Moderate launch speed, high randomness for flicker.
    linear_speed: Some((55.0, 0.5)),
    // Positive accel along travel: rising heat speeds up as it climbs.
    linear_acceleration: Some((35.0, 0.3)),
    // Fixed upward bias with wide scatter — the flame leans up but spreads.
    direction: Some(((0.0, 1.0), 0.35)),
    angular_speed: None,
    angular_acceleration: None,
    // Big soft particles so the body is a glowing mass, not visible motes.
    scale: Some((16.0, 0.4)),
    // Base tint; the color_curve drives the warm HDR gradient over lifetime.
    color: Some((red: 1.0, green: 0.55, blue: 0.2, alpha: 1.0)),
    gravity_direction: None,
    gravity_speed: None,
    // Light damping so the climb settles near the top before the particle dies.
    linear_damp: Some((0.8, 0.0)),
    angular_damp: None,
    // Pop in, hold, then collapse to nothing at the flame tip.
    scale_curve: Some((points: [
        (0.4, 0.0, None),
        (1.0, 0.25, Some(SineOut)),
        (0.0, 1.0, Some(SineInOut)),
    ])),
    // White-hot base (all channels > 1.0 -> bloom) -> orange -> deep red, fading out.
    color_curve: Some((points: [
        ((red: 2.6, green: 2.1, blue: 1.3, alpha: 1.0), 0.0, None),
        ((red: 2.2, green: 1.0, blue: 0.25, alpha: 0.95), 0.45, Some(SineOut)),
        ((red: 0.7, green: 0.12, blue: 0.05, alpha: 0.0), 1.0, Some(SineInOut)),
    ])),
    attractors: None,
    // World-space: particles stay put as they rise, so the column reads upward.
    relative_positioning: Some(false),
)
