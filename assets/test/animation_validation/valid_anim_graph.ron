(
    id: "test_valid",
    clip: "skill",
    entry: "windup",
    nodes: {
        "impact": (
            frames: (4, 7),
            cues: [
                (at: 5, command: ReleaseKernel(())),
            ],
        ),
        "windup": (
            frames: (0, 3),
            on_enter: [
                SpawnParticle(
                    name: "impact_particle",
                    origin: CasterCenter,
                    motion: ArcToTarget,
                ),
            ],
        ),
    },
    transitions: [
        (
            from: "windup",
            to: Node("impact"),
            when: TimeInNode,
        ),
        (
            from: "impact",
            to: Exit,
            when: Always,
        ),
    ],
)
