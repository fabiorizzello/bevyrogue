(
    id: "renamon_skill",
    clip: "skill",
    entry: "diamond_storm_cast",
    nodes: {
        "diamond_storm_cast": (
            frames: (45, 49),
            on_enter: [
                SpawnParticle(
                    name: "diamond_storm_leaf",
                    origin: CasterCenter,
                    motion: ArcToTarget,
                ),
            ],
        ),
        "diamond_storm_impact": (
            frames: (50, 53),
            cues: [
                (at: 1, command: ReleaseKernel(())),
            ],
        ),
        "diamond_storm_recover": (
            frames: (54, 54),
        ),
    },
    transitions: [
        (
            from: "diamond_storm_cast",
            to: Node("diamond_storm_impact"),
            when: TimeInNode,
        ),
        (
            from: "diamond_storm_impact",
            to: Node("diamond_storm_recover"),
            when: TimeInNode,
        ),
        (
            from: "diamond_storm_recover",
            to: Exit,
            when: Always,
        ),
    ],
)
